      "id": "after_prayer_01",
      "text_ar": "أَسْتَغْفِرُ اللَّهَ.",
      "source": "رواه مسلم",
      "repeat": 3
    },
    {
      "id": "after_prayer_02",
      "text_ar": "اللَّهُمَّ أَنْتَ السَّلَامُ، وَمِنْكَ السَّلَامُ، تَبَارَكْتَ يَا ذَا الْجَلَالِ وَالْإِكْرَامِ.",
      "source": "رواه مسلم",
      "repeat": 1
    },
    {
      "id": "after_prayer_03",
      "text_ar": "لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ، لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ، وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ. اللَّهُمَّ لاَ مَانِعَ لِمَا أَعْطَيْتَ، وَلاَ مُعْطِيَ لِمَا مَنَعْتَ، وَلاَ يَنْفَعُ ذَا الْجَدِّ مِنْكَ الْجَدُّ.",
      "source": "رواه البخاري ومسلم",
      "repeat": 1
    },
    {
      "id": "after_prayer_04",
      "text_ar": "سُبْحَانَ اللَّهِ.",
      "source": "رواه مسلم",
      "repeat": 33
    },
    {
      "id": "after_prayer_05",
      "text_ar": "الْحَمْدُ لِلَّهِ.",
      "source": "رواه مسلم",
      "repeat": 33
    },
    {
      "id": "after_prayer_06",
      "text_ar": "اللَّهُ أَكْبَرُ.",
      "source": "رواه مسلم",
      "repeat": 34
    }
  ]
